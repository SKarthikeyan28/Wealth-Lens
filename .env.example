# Database
POSTGRES_USER=wealthlens
POSTGRES_PASSWORD=wealthlens
POSTGRES_DB=wealthlens
DATABASE_URL=postgresql://wealthlens:wealthlens@db:5432/wealthlens

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-in-production

# Auth — JWT
JWT_SECRET_KEY=change-me-min-32-chars-random-secret
