JWT_REFRESH_EXPIRE_DAYS=7

# TOTP 2FA — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=change-me-generate-with-fernet

# Chatbot — Anthropic LLM API
ANTHROPIC_API_KEY=change-me-anthropic-api-key
CHATBOT_MODEL=claude-opus-4-8
